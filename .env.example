# Copy this file to .env and add local credentials.

GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
APOLLO_API_KEY=
AI_PROVIDER_API_KEY=
DATABASE_URL=

# Backend Supabase authentication
SUPABASE_URL=
# Optional override for the expected access-token audience. Supabase uses
# "authenticated" by default.
SUPABASE_JWT_AUDIENCE=authenticated
# Required only for legacy Supabase HS256 JWT projects. Do not expose this value.
SUPABASE_JWT_SECRET=

# Backend only; never expose this key to the frontend.
SUPABASE_SERVICE_ROLE_KEY=

# FastAPI resume-upload validation limit. The Storage bucket uses the same
# 10 MB limit.
RESUME_MAX_UPLOAD_BYTES=10485760

# Backend-only AI provider configuration. Select `gemini` or `openai`.
AI_PROVIDER=gemini

GEMINI_API_KEY=
# Verified stable Gemini Developer API model (official docs checked 2026-07-17).
GEMINI_MODEL=gemini-2.5-flash

OPENAI_API_KEY=
OPENAI_MODEL=
