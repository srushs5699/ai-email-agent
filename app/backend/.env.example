# Copy to a local environment source and provide the public Supabase project URL.
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase access tokens use this audience unless the project is configured otherwise.
SUPABASE_JWT_AUDIENCE=authenticated

# Legacy HS256 projects only. Leave unset when the project uses JWKS signing keys.
# Never expose this value to the frontend or commit a real secret.
SUPABASE_JWT_SECRET=

# Backend only. This key may bypass RLS for trusted file/database work and must
# never be copied into frontend environment files or source code.
SUPABASE_SERVICE_ROLE_KEY=

# FastAPI resume-upload validation limit. The Storage bucket uses the same
# 10 MB limit.
RESUME_MAX_UPLOAD_BYTES=10485760

# Backend-only AI provider configuration. Select `gemini` or `openai`.
AI_PROVIDER=gemini

GEMINI_API_KEY=
# Verified stable Gemini Developer API model (official docs checked 2026-07-17).
GEMINI_MODEL=gemini-2.5-flash

OPENAI_API_KEY=
OPENAI_MODEL=
