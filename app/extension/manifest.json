{
  "manifest_version": 3,
  "name": "AI Email Agent LinkedIn Capture",
  "version": "0.1.0",
  "description": "Review public LinkedIn post details before importing them into AI Email Agent.",
  "action": { "default_popup": "popup/popup.html", "default_title": "Capture LinkedIn post" },
  "background": { "service_worker": "background/service-worker.js", "type": "module" },
  "permissions": ["activeTab", "storage", "tabs", "scripting"],
  "host_permissions": ["https://www.linkedin.com/*", "https://linkedin.com/*", "http://localhost:5173/*"],
  "optional_host_permissions": ["https://*/*", "http://*/*"],
  "content_scripts": [
    { "matches": ["https://www.linkedin.com/*", "https://linkedin.com/*"], "js": ["content/linkedin-content.js"], "run_at": "document_idle" },
    { "matches": ["http://localhost:5173/*"], "js": ["content/application-bridge.js"], "run_at": "document_idle" }
  ]
}
